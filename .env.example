# Copie para .env e preencha com os dados do Firebase Console
# https://console.firebase.google.com/

VITE_FIREBASE_API_KEY=sua-api-key
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
# Bucket do Cloud Storage (mesmo projeto). Na cota free não cobra pelo uso leve.
# Crie em: https://console.cloud.google.com/storage/browser
# Nomes comuns: seu-projeto.appspot.com  OU  seu-projeto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:000000000000
