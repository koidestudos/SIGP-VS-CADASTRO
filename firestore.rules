rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isBootstrapAdminEmail() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() == 'sandgyferreira@gmail.com';
    }

    function isAdmin() {
      return isSignedIn() && (
        isBootstrapAdminEmail()
        || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }

    function validProgramacaoFields(data) {
      return data.keys().hasAll(['titulo', 'coordenacaoId', 'dataInicial', 'dataFinal', 'status', 'criadoPor'])
        && data.titulo is string
        && data.titulo.size() > 0
        && data.titulo.size() <= 500
        && data.coordenacaoId is string
        && data.coordenacaoId.size() <= 80
        && data.dataInicial is string
        && data.dataFinal is string
        && data.status is string
        && validStatus(data.status)
        && data.criadoPor is string
        && data.criadoPor.size() <= 128
        && (!('responsavel' in data) || (data.responsavel is string && data.responsavel.size() <= 200))
        && (!('objetivo' in data) || (data.objetivo is string && data.objetivo.size() <= 5000))
        && (!('observacoes' in data) || (data.observacoes is string && data.observacoes.size() <= 5000))
        && (!('equipe' in data) || data.equipe is list)
        && (!('equipe' in data) || data.equipe.size() <= 50)
        && (
          data.status in ['Rascunho', 'Realizada', 'Cancelada', 'Reprovada']
          || data.equipe.size() >= 1
        )
        && (!('municipioIds' in data) || data.municipioIds is list)
        && (!('municipioIds' in data) || data.municipioIds.size() <= 20);
    }

    function validUserProfile(data) {
      return data.nome is string
        && data.nome.size() <= 200
        && data.email is string
        && data.email.size() <= 320
        && (!('role' in data) || data.role in ['admin', 'usuario']);
    }

    function canSetAdminRole(data) {
      return isBootstrapAdminEmail() && data.role == 'admin';
    }

    function isRealizadaPorAnexoUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'atualizadoEm'])
        && request.resource.data.status == 'Realizada'
        && resource.data.status != 'Reprovada'
        && resource.data.status != 'Cancelada';
    }

    match /programacoes/{programacaoId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && validProgramacaoFields(request.resource.data)
        && request.resource.data.criadoPor == request.auth.uid;

      allow update: if isSignedIn() && isRealizadaPorAnexoUpdate();

      allow update: if isSignedIn()
        && validProgramacaoFields(request.resource.data)
        && request.resource.data.criadoPor == resource.data.criadoPor;

      allow update: if isAdmin()
        && validProgramacaoFields(request.resource.data)
        && request.resource.data.criadoPor == resource.data.criadoPor;

      allow delete: if isSignedIn() && resource.data.criadoPor == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /logistica/{logisticaId} {
      allow read: if isSignedIn();

      allow create, update: if isSignedIn()
        && request.resource.data.keys().hasAll(['programacaoId', 'municipioId', 'situacao'])
        && request.resource.data.programacaoId is string
        && request.resource.data.municipioId is string
        && request.resource.data.situacao in ['Solicitado', 'Confirmado']
        && request.resource.data.transporte is bool
        && request.resource.data.alimentacao is bool;

      allow delete: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId)
        && validUserProfile(request.resource.data)
        && (!('role' in request.resource.data) || canSetAdminRole(request.resource.data));

      allow update: if isOwner(userId)
        && validUserProfile(request.resource.data)
        && (
          !('role' in request.resource.data)
          || request.resource.data.role == resource.data.get('role', 'usuario')
          || canSetAdminRole(request.resource.data)
        );

      allow update: if isAdmin()
        && validUserProfile(request.resource.data)
        && request.resource.data.role in ['admin', 'usuario'];
    }

    match /notificacoes/{notifId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['tipo', 'titulo', 'lido', 'criadoEm'])
        && request.resource.data.tipo is string
        && request.resource.data.tipo in ['programacao_enviada', 'programacao_anexo']
        && request.resource.data.titulo is string
        && request.resource.data.titulo.size() <= 500
        && request.resource.data.lido is bool;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /programacao_anexos/{anexoId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll([
          'programacaoId', 'programacaoTitulo', 'nomeArquivo', 'storagePath',
          'downloadUrl', 'enviadoPor', 'enviadoPorNome', 'enviadoEm'
        ])
        && request.resource.data.programacaoId is string
        && request.resource.data.programacaoId.size() > 0
        && request.resource.data.programacaoTitulo is string
        && request.resource.data.programacaoTitulo.size() <= 500
        && request.resource.data.nomeArquivo is string
        && request.resource.data.nomeArquivo.size() > 0
        && request.resource.data.nomeArquivo.size() <= 300
        && request.resource.data.storagePath is string
        && request.resource.data.downloadUrl is string
        && request.resource.data.enviadoPor == request.auth.uid
        && request.resource.data.enviadoPorNome is string
        && request.resource.data.enviadoEm is string
        && (!('tamanho' in request.resource.data) || request.resource.data.tamanho is number)
        && (!('mimeType' in request.resource.data) || request.resource.data.mimeType is string)
        && (!('coordenacaoId' in request.resource.data) || request.resource.data.coordenacaoId is string)
        && (!('enviadoPorEmail' in request.resource.data) || request.resource.data.enviadoPorEmail is string)
        && (!('chunkCount' in request.resource.data) || request.resource.data.chunkCount is number)
        && (!('storedIn' in request.resource.data) || request.resource.data.storedIn in [
          'storage', 'firestore', 'firestore-chunks'
        ]);

      allow update, delete: if isAdmin();

      match /chunks/{chunkId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.keys().hasAll(['index', 'data'])
          && request.resource.data.index is number
          && request.resource.data.data is string
          && request.resource.data.data.size() <= 450000
          && get(/databases/$(database)/documents/programacao_anexos/$(anexoId)).data.enviadoPor == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    match /coordenacoes/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /municipios/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /regionais/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /suporte_admins/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isOwner(docId);
    }

    match /suporte_chats/{chatId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);

      match /mensagens/{msgId} {
        allow read: if isSignedIn() && (
          isAdmin() || get(/databases/$(database)/documents/suporte_chats/$(chatId)).data.userId == request.auth.uid
        );
        allow create: if isSignedIn() && request.resource.data.texto is string
          && request.resource.data.texto.size() > 0
          && request.resource.data.texto.size() <= 2000;
        allow delete: if isAdmin() || (
          isSignedIn()
          && get(/databases/$(database)/documents/suporte_chats/$(chatId)).data.userId == request.auth.uid
        );
      }
    }
  }
}
